---
interface Props {
  title: string
  content: Array<any>
}

const { title, content } = Astro.props
---

<div class="flex flex-col gap-4">
  <div
    class="rounded-2xl border border-[#0d1017]/10 bg-white/70 p-5 shadow-[0_20px_50px_rgba(0,0,0,0.05)] dark:bg-white/5 dark:border-white/10"
  >
    <div class="flex items-center justify-between mb-4">
      <h2 class="text-lg font-semibold tracking-tight">{title}</h2>
      <span
        class="h-2 w-2 rounded-full bg-gradient-to-r from-[#fb9d72] to-[#8dd9c9] block"
      ></span>
    </div>
    <div class="flex flex-col">
      {
        content.map((element: any, index: number) => (
          <div class="relative pl-6 pb-6 last:pb-0">
            <span
              class="absolute left-0 top-1 h-3 w-3 rounded-full border border-[#0d1017]/20 bg-white dark:bg-[#0b0d12] dark:border-white/30"
            ></span>
            {
              index < content.length - 1 && (
                <span
                  class="absolute left-[5px] top-4 h-[calc(100%-14px)] w-px bg-[#0d1017]/10 dark:bg-white/15"
                ></span>
              )
            }
            <div class="flex items-baseline justify-between gap-3">
              <h3 class="font-semibold text-lg">{element.name}</h3>
              <span
                class="rounded-full border border-[#0d1017]/15 px-3 py-1 text-xs font-semibold text-[#0d1017] dark:text-[#f6f1e7] dark:border-white/15"
              >
                {element.interval}
              </span>
            </div>
            <p class="mt-1 text-sm text-[#3a3f48] dark:text-slate-300">
              {element.title}
            </p>
          </div>
        ))
      }
    </div>
  </div>
</div>
