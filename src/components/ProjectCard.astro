---
import { Card, CardContent, CardTitle, CardHeader } from '../components/ui/card'
import { Badge } from '../components/ui/badge'

interface Props {
  title: string
  description: string
  src: string
  alt: string
  link: string
  technologies: Array<any>
}

const { title, description, src, alt, link, technologies } = Astro.props
---

<Card
  key={title}
  className="group relative overflow-hidden rounded-2xl border border-[#0d1017]/10 bg-white/80 shadow-[0_20px_50px_rgba(0,0,0,0.05)] backdrop-blur transition-transform duration-300 hover:-translate-y-1 hover:shadow-[0_25px_60px_rgba(0,0,0,0.08)] dark:bg-white/5 dark:border-white/10"
>
  <div class="absolute inset-x-0 top-0 h-[3px] bg-gradient-to-r from-[#fb9d72] via-[#8dd9c9] to-[#6f7bff] opacity-70"></div>
  <CardHeader className="p-0">
    <a
      href={link}
      target="_blank"
      class="relative block w-full aspect-[16/9] overflow-hidden rounded-[16px]"
    >
      <img
        src={src}
        alt={alt}
        class="object-cover w-full h-full transition-transform duration-500 group-hover:scale-[1.03]"
      />
      <div
        class="absolute inset-0 bg-gradient-to-t from-[#0d1017]/55 via-[#0d1017]/5 to-transparent opacity-0 transition-opacity duration-300 group-hover:opacity-100 dark:from-black/55"
      ></div>
    </a>
  </CardHeader>
  <CardContent className="p-6 space-y-4">
    <div class="flex items-start justify-between gap-4">
      <CardTitle className="text-xl md:text-[22px] leading-tight">{title}</CardTitle>
      <a
        href={link}
        target="_blank"
        class="inline-flex items-center gap-2 rounded-full border border-[#0d1017]/15 px-3 py-1 text-xs font-semibold text-[#0d1017] transition-colors duration-300 hover:border-[#0d1017] dark:text-[#f6f1e7] dark:border-white/20 dark:hover:border-white/40"
      >
        View
        <span aria-hidden="true" class="transition-transform duration-300 group-hover:translate-x-0.5">→</span>
      </a>
    </div>
    <p class="text-sm text-[#3a3f48] dark:text-slate-300 leading-relaxed">
      {description}
    </p>
    <div class="flex flex-wrap gap-2 pt-1">
      {
        technologies.map((tech) => (
          <Badge
            variant="secondary"
            className="border-0 bg-[#0d1017]/6 text-[#0d1017] dark:bg-white/10 dark:text-[#f6f1e7]"
          >
            {tech.name}
          </Badge>
        ))
      }
    </div>
  </CardContent>
</Card>
